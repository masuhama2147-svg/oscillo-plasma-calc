# =============================================================================
# ⚠️ 野村研究室 機密データ — 絶対に公開しないこと ⚠️
# =============================================================================
# 以下のファイルは研究室内 IP（知的財産）であり、GitHub へ push してはいけない。
# もし誤って commit してしまった場合は即座に `git rm --cached <file>` + 新規 commit。
# push まで行ってしまった場合は履歴書き換え (`git filter-branch` or BFG) が必要。
# -----------------------------------------------------------------------------

# 実測データ・論文アーカイブ（Excel 原本）
*.xlsx
*.xlsm
*.xlsb

# Excel から派生した CSV / レポート（測定条件を含むため非公開）
data_csv/*.csv
!data_csv/.gitkeep
reports/*.md
reports/*.pdf
!reports/.gitkeep

# オシロ・分光測定の生データ（bin, hdf5 等）
*.bin
*.h5
*.hdf5
*.mat

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
*.whl

# venv
.venv/
venv/
env/
.env

# pytest / mypy / ruff
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# =============================================================================
# IDE / OS
# =============================================================================
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

